# =============================================================================
# M-Motors — Variables d'environnement (développement local / Docker Compose)
# Copier vers .env : cp .env.example .env
# Ne jamais committer .env (secrets réels).
# =============================================================================

# --- Application ---
ENV=development
SECRET_KEY=dev-changez-moi-minimum-32-caracteres-recommande

# --- Base de données (PostgreSQL — aligné sur les tests d'intégration CI) ---
POSTGRES_USER=mmotors
POSTGRES_PASSWORD=mmotors_dev
POSTGRES_DB=mmotors
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# URL async (FastAPI / SQLAlchemy) — en Docker: host = nom du service (ex. postgres)
DATABASE_URL=postgresql+asyncpg://mmotors:mmotors_dev@localhost:5432/mmotors

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- API (CORS / origines autorisées, séparées par des virgules) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend (Next.js — préfixe NEXT_PUBLIC_ exposé au navigateur) ---
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Images Docker (CI/CD — déploiement avec IMAGE_TAG=sha-<court>) ---
# IMAGE_TAG=latest
