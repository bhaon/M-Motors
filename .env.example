# Variables pour Docker Compose (copier vers .env à la racine du dépôt pour les tests locaux).
# Sur les serveurs, utiliser .env.staging / .env.production selon CICD-Workflow-doc.md.

# Propriétaire GitHub (namespace GHCR) — obligatoire pour pull staging/production
GHCR_OWNER=votre-org-ou-user-github

# Tag d’image (CI : IMAGE_TAG=sha-<short-sha>)
IMAGE_TAG=local

# Ports optionnels
# FRONTEND_PORT=3000
# BACKEND_PORT=8000

# Backend (pile complète uniquement)
# DATABASE_URL=postgresql+asyncpg://mmotors:mmotors@postgres:5432/mmotors
# REDIS_URL=redis://redis:6379/0
# SECRET_KEY=changez-moi
