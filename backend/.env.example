# =============================================================================
# M-Motors — Backend FastAPI (tests / dev local sans Docker)
# Copier vers .env — cp .env.example .env
# Valeurs alignées sur les jobs Pytest du workflow GitHub Actions.
# =============================================================================

# Tests unitaires (SQLite) — job test-backend-unit
# ENV=test
# SECRET_KEY=ci-test-secret
# DATABASE_URL=sqlite:///./test.db

# Tests d’intégration (PostgreSQL + Redis) — jobs locaux ou CI
ENV=test
SECRET_KEY=ci-test-secret
DATABASE_URL=postgresql://mmotors:mmotors_test@localhost:5432/mmotors_test
REDIS_URL=redis://localhost:6379/0

# Développement local avec Postgres/Redis lancés localement
# ENV=development
# DATABASE_URL=postgresql://mmotors:mmotors_dev@localhost:5432/mmotors
# REDIS_URL=redis://localhost:6379/0
